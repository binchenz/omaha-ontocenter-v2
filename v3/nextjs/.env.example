# Postgres for the Next.js auth/session schema (separate from the Python API DB).
DATABASE_URL=postgresql://ontocenter:ontocenter@localhost:5432/ontocenter_v3

# Where the Python API listens. Used by services/pythonApi.ts and lib/proxyToPython.ts.
PYTHON_API_URL=http://127.0.0.1:8000

# NextAuth — replace in production.
NEXTAUTH_SECRET=dev-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Shared secret with the Python API. Must equal INTERNAL_API_SECRET in
# v3/python-api/.env. Empty in dev (Python middleware no-ops). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Server-only — never expose under NEXT_PUBLIC_*.
INTERNAL_API_SECRET=

# --- LLM (DeepSeek / OpenAI-compatible) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
