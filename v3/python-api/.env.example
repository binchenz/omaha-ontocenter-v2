# --- Database ---
# Async drivers required (sqlite+aiosqlite, postgresql+asyncpg, mysql+aiomysql).
# Sync URLs (sqlite:///, postgresql://) are auto-rewritten as a courtesy, but
# prefer the async form here.
DATABASE_URL=sqlite+aiosqlite:///./omaha.db

# --- Security ---
# JWT-style signing key. MUST be replaced in production (the app refuses to
# start under ENV=production with the default value).
SECRET_KEY=dev-secret-change-in-production

# Shared secret between the Next.js server and this Python API.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - Leave blank in dev → middleware is a no-op (no header required).
# - REQUIRED in production: when set, every request without a matching
#   `X-Internal-Auth` header (except /health) is rejected with 401.
# - The Next.js server reads INTERNAL_API_SECRET from its own env and
#   injects the header on every Python call; both sides must agree.
INTERNAL_API_SECRET=

# --- LLM ---
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=

# --- Storage ---
DELTA_STORAGE=./data/delta
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- MCP ---
MCP_HOST=0.0.0.0
MCP_PORT_START=9000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
