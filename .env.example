# Application
APP_NAME=Omaha OntoCenter
APP_VERSION=1.0.0
DEBUG=false

# Database (SQLite for single-node deployment)
DATABASE_URL=sqlite:////app/data/omaha.db

# JWT — change this in production!
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — set to your domain in production
CORS_ORIGINS=["http://localhost","http://localhost:80"]

# Tushare Pro API token (required for A-share financial data)
TUSHARE_TOKEN=

# LLM for Chat feature (DeepSeek or OpenAI compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# DataHub (optional)
DATAHUB_GMS_URL=
DATAHUB_GMS_TOKEN=
